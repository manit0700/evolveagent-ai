OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
DEFAULT_PROVIDER=openai
LLM_MODE=mock
APP_NAME=EvolveAgent AI
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_MASTER_MODEL=gpt-5.5
OPENAI_REASONING_MODEL=gpt-5.4
OPENAI_CHEAP_MODEL=gpt-5.4-mini
ANTHROPIC_STRONG_MODEL=claude-opus-4.5
ANTHROPIC_BALANCED_MODEL=claude-sonnet-4.5
ANTHROPIC_FAST_MODEL=claude-haiku-4.5
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GEMINI_PRO_MODEL=gemini-pro
GEMINI_FAST_MODEL=gemini-flash
GEMINI_MODEL=gemini-1.5-pro
MISTRAL_STRONG_MODEL=mistral-large
MISTRAL_CODE_MODEL=devstral
MISTRAL_FAST_MODEL=mistral-small
MISTRAL_MODEL=mistral-large-latest
IMAGE_MODE=mock
IMAGE_PROVIDER=mock_image
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_SIZE=1024x1024
TRANSCRIPTION_MODE=mock
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Linear Integration
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_PROJECT_ID=
LINEAR_WORKSPACE_NAME=
LINEAR_SYNC_ENABLED=false
LINEAR_POLL_INTERVAL_SECONDS=60
LINEAR_CURSOR_WORKER=true

# Autonomous Codex Worker (disabled by default — manual trigger only)
CODEX_WORKER_ENABLED=false
LINEAR_AUTONOMOUS_CODEX_WORKER=false
CODEX_CLI_COMMAND=codex
CODEX_WORKER_MODE=manual_trigger
CODEX_MAX_FILES_CHANGED=8

# Git Automation Safety
AUTO_GIT_PUSH=false
GIT_DEFAULT_BRANCH=main
GIT_REMOTE_NAME=origin

# Approval Workflow
# Optional webhook called when a new approval is requested. Leave blank to disable.
APPROVAL_WEBHOOK_URL=

# Slack Notifications (disabled by default)
# Incoming webhook URL for posting run summaries. Never commit a real URL.
SLACK_NOTIFICATIONS_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_DEFAULT_CHANNEL=
